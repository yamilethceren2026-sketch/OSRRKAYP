@model OSRRKAYP.BusinessLogic.DTOs.UpdateProductRequest

@{
    ViewData["Title"] = "Editar";
}

<h1>Editar</h1>

<h4>Producto</h4>

<hr />

<div class="row">

    <div class="col-md-4">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <input type="hidden"
                   asp-for="ProductId" />

            <div class="form-group">

                <label class="control-label">
                    Nombre del Producto
                </label>

                <input asp-for="ProductName"
                       class="form-control" />

                <span asp-validation-for="ProductName"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mt-3">

                <input type="submit"
                       value="Guardar"
                       class="btn btn-primary" />

                <a asp-action="Index"
                       class="btn btn-info">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync
        ("_ValidationScriptsPartial");
    }
}