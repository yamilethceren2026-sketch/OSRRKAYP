@model OSRRKAYP.BusinessLogic.DTOs.CreateBrandRequest

@{
    ViewData["Title"] = "Crear";
}

<h1>Crear</h1>

<h4>Marca</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="form-group">
                <label class="control-label">
                    Nombre
                </label>

                <input asp-for="BrandName"
                       class="form-control" />

                <span asp-validation-for="BrandName"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group mt-3">

                <input type="submit"
                       value="Crear"
                       class="btn btn-primary" />

                <a asp-action="Index"
                       class="btn btn-info">
                    Cancelar
                </a>

            </div>

        </form>

    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync
        ("_ValidationScriptsPartial");
    }
}
