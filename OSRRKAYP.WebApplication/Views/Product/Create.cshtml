@model OSRRKAYP.BusinessLogic.DTOs.CreateManufacturerDto

@{
    ViewData["Title"] = "Crear";
}

<h1>Crear</h1>

<h4>Crear Fabricante</h4>

<hr />

<form asp-action="Create">

    <div asp-validation-summary="ModelOnly"
         class="text-danger">
    </div>

    <div class="row">

        <div class="form-group col-6">

            <label asp-for="CompanyName"
                   class="control-label">
                Nombre de la Empresa
            </label>

            <input asp-for="CompanyName"
                   class="form-control" />

            <span asp-validation-for="CompanyName"
                  class="text-danger">
            </span>

        </div>

        <div class="form-group col-6">

            <label asp-for="Country"
                   class="control-label">
                País
            </label>

            <input asp-for="Country"
                   class="form-control" />

            <span asp-validation-for="Country"
                  class="text-danger">
            </span>

        </div>

    </div>

    <div class="row">

        <div class="form-group mt-3">

            <input type="submit"
                   value="Crear"
                   class="btn btn-primary" />

            <a asp-action="Index"
                   class="btn btn-info">
                Cancelar
            </a>

        </div>

    </div>

</form>

@section Scripts
{
    @{
        await Html.RenderPartialAsync
        ("_ValidationScriptsPartial");
    }
}
